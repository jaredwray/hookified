{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",

        /* Emit */
        "noEmit": true,

        /* Interop Constraints */
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "allowImportingTsExtensions": false,

        /* Type Checking */
        "strict": true,

        /* Completeness */
        "skipLibCheck": true,
        "lib": [
            "ESNext", "DOM"
        ],
        "types": ["node"]
    },
    "include": [
        "src/**/*.ts",
        "test/**/*.ts",
        "benchmark/**/*.ts",
        "scripts/**/*.ts"
    ]
}
